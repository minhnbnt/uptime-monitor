# For Docker Compose (copy to .env):
#   DB_HOST=postgres
#   REDIS_ADDR=redis:6379
#   TEMPORAL_HOST=host.docker.internal:7233
#
# For local development (values below):

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=uptime_monitor

REDIS_ADDR=localhost:6379
REDIS_DB=0

JWT_KEY=your-secret-key-here

TEMPORAL_HOST=localhost:7233
TEMPORAL_TASK_QUEUE=ping-task-queue
TEMPORAL_WORKFLOW_NAME=ping-workflow

LOG_LEVEL=info
