# ── Database ──────────────────────────────
DB_HOST=pgbouncer
DB_PORT=6432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=uptime_monitor

# ── Redis ─────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ───────────────────────────────────
JWT_KEY=your-secret-key-here

# ── Temporal (optional) ───────────────────
# TEMPORAL_HOST=localhost:7233
# TEMPORAL_TASK_QUEUE=ping-task-queue
# TEMPORAL_WORKFLOW_NAME=ping-workflow
# TEMPORAL_DIGEST_TASK_QUEUE=digest-task-queue

# ── SMTP (optional) ───────────────────────
# SMTP_HOST=localhost
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@uptime.local

# ── Logging ───────────────────────────────
LOG_LEVEL=info
