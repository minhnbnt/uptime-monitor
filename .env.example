# ──────────────────────────────────────────
# Uptime Monitor — Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env and adjust as needed.

# ── Database ──────────────────────────────
# Use "pgbouncer" / "postgres" when running via compose,
# or "localhost" when running natively.
DB_HOST=pgbouncer
DB_PORT=6432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=uptime_monitor

# ── Redis ─────────────────────────────────
# Use "redis" when running via compose,
# or "localhost" when running natively.
REDIS_ADDR=redis:6379
REDIS_DB=0
# REDIS_PASSWORD=

# ── JWT ───────────────────────────────────
JWT_KEY=your-secret-key-here

# ── Temporal (optional, only for temporal scheduler backend) ──
# TEMPORAL_HOST=localhost:7233
# TEMPORAL_TASK_QUEUE=ping-task-queue
# TEMPORAL_WORKFLOW_NAME=ping-workflow

# ── OpenSearch (optional) ─────────────────
# OPENSEARCH_ADDRESSES=https://localhost:9200

# ── Logging ───────────────────────────────
LOG_LEVEL=info
